{% extends 'base.html.twig' %}
{% block title %}Mes candidatures{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Mes candidatures</h1>
</div>
{% for application in applications %}
<div class="content-card">
    <a href="/offers/show?id={{ application.offre_id }}" class="content-card__title">{{ application.titre }}</a>
    <p class="offer-detail__company">{{ application.nom }}</p>
    <p class="offer-detail__location">{{ application.ville }}</p>
    <p class="offer-detail__date">Postulé le : {{ application.date_candidature }}</p>
    <a href="/storage/file?path={{ application.chemin_cv }}" target="_blank">Voir CV</a>
    <a href="/storage/file?path={{ application.chemin_lm }}" target="_blank">Voir LM</a>
</div>
{% endfor %}
{% endblock %}