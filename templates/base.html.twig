<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="http://assets.stagium.fr/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Stagium - {% block title %}{% endblock %}</title>
</head>
<body>
    <div id="navOverlay" class="nav-overlay"></div>
    <aside id="sidebar">
        <div class="sidebar__header">
            <img src="https://assets.stagium.fr/img/logo.svg" alt="Logo Stagium">
            <button class="close-btn" id="sidebarClose">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="3" y1="3" x2="17" y2="17"/>
                    <line x1="17" y1="3" x2="3" y2="17"/>
                </svg>
            </button>
        </div>
        <nav>
            <ul>
                <li><a href="/">Acceuil</a></li>
                <li><a href="/offers">Offres de stage</a></li>
                <li><a href="/companies">Entreprises</a></li>
                {% if user_role in ['pilote', 'administrateur'] %}
                <li><a href="/students">Étudiants</a></li>                {% endif %}
                {% if user_role == 'administrateur' %}
                <li><a href="/pilots">Pilotes</a></li>
                {% endif %}
                {% if user_role == 'etudiant' %}
                <li><a href="/wishlist">Favoris</a></li>
                <li><a href="/student/applications">Mes candidatures</a></li>
                {% endif %}
                {% if user_role == 'pilote' %}
                <li><a href="/pilot/applications">Suivi candidatures</a></li>
                {% endif %}


                {% if is_logged_in %}
                <li><a href="/logout">Déconnexion</a></li>
                {% endif %}
            </ul>
        </nav>
    </aside>

    <header class="header">
        <button class="header__burger" id="burgerBtn">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <a href="/" class="header__logo"><img src="https://assets.stagium.fr/img/logo.svg" alt="Logo Stagium"></a>
        <nav class="header__nav">
            <ul>
                <li><a href="/">Acceuil</a></li>
                <li><a href="/offers">Offres de stage</a></li>
                <li><a href="/companies">Entreprises</a></li>
                {% if user_role in ['pilote', 'administrateur'] %}
                <li><a href="/students">Étudiants</a></li>
                {% endif %}
                {% if user_role == 'administrateur' %}
                <li><a href="/pilots">Pilotes</a></li>
                {% endif %}
                {% if user_role == 'etudiant' %}
                <li><a href="/wishlist">Favoris</a></li>
                <li><a href="/student/applications">Mes candidatures</a></li>
                {% endif %}
                {% if user_role == 'pilote' %}
                <li><a href="/pilot/applications">Suivi candidatures</a></li>
                {% endif %}


                {% if is_logged_in %}
                <li><a href="/logout">Déconnexion</a></li>
                {% endif %}
            </ul>
        </nav>
        <div class="header__actions">
            {% if is_logged_in %}
                <div class="avatar">{{ user_initials }}</div>
            {% else %}
                <a href="/login" class="btn btn--primary">Connexion</a>
            {% endif %}
        </div>
    </header>
    <div class="main">
    {% block content %}{% endblock %}
    </div>
    <script src="https://assets.stagium.fr/js/app.js" defer></script>

    <footer class="site-footer">
        <a href="/mentions-legales">Mentions légales</a>
    </footer>
</body>
</html>
