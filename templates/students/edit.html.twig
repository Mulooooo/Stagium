{% extends 'base.html.twig' %}
{% block title %}Modifier {{ student.prenom }} {{ student.nom }}{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Modifier {{ student.prenom }} {{ student.nom }}</h1>
    <a href="/students/show?id={{ student.id }}" class="btn btn--primary">Retour</a>
</div>
{% if error is defined and error %}
<div class="alert alert--error">{{ error }}</div>
{% endif %}
<div class="content-card">
    <form method="post" class="auth-form">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        
        <div class="form-field">
            <label class="form-field__label" for="nom">Nom</label>
            <input class="form-field__input" type="text" id="nom" name="nom" value="{{ student.nom }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="prenom">Prénom</label>
            <input class="form-field__input" type="text" id="prenom" name="prenom" value="{{ student.prenom }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="email">Email</label>
            <input class="form-field__input" type="email" id="email" name="email" value="{{ student.email }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="mot_de_passe">Mot de passe</label>
            <input class="form-field__input" type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Laisser vide pour ne pas modifier">
        </div>
        <button type="submit" class="btn btn--primary">Modifier</button>
    </form>
</div>
{% endblock %}