{% extends 'base.html.twig' %}
{% block title %}{{ student.prenom }} {{ student.nom }}{% endblock %}
{% block content %}
<div class="page-header">
    <h1>{{ student.prenom }} {{ student.nom }}</h1>
    <div class="offer-detail__actions">
        <a href="/students/edit?id={{ student.id }}" class="btn btn--primary">Modifier</a>
        <form method="post" action="/students/delete">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        
            <input type="hidden" name="id" value="{{ student.id }}">
            <button type="submit" class="btn btn--danger">Supprimer</button>
        </form>
    </div>
</div>
{% if error is defined and error %}
<div class="alert alert--error">{{ error }}</div>
{% endif %}
<div class="offer-detail">
    <p class="offer-detail__company">{{ student.email }}</p>
</div>
{% endblock %}