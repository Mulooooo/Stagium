{% extends 'base.html.twig' %}
{% block title %}
    Etudiants
{% endblock %}
{% block content %}
    <div>
    {% for student in students %}
        <div>
            <a href="/students/show?id={{ student.id }}">{{ student.prenom }} {{ student.nom }}</a>
            <p>{{ student.email }}</p>
        </div>
    {% endfor %}
    </div>
    {% if total_pages > 1 %}
    {% if current_page > 1 %}
        <a href="/students?page={{ current_page - 1 }}">Précédent</a>
    {% endif %}
    
    <span>Page {{ current_page }} / {{ total_pages }}</span>
    
    {% if current_page < total_pages %}
        <a href="/students?page={{ current_page + 1 }}">Suivant</a>
    {% endif %}
    {% endif %}
{% endblock %}