{% extends 'base.html.twig' %}
{% block title %}Créer un étudiant{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Créer un étudiant</h1>
    <a href="/students" class="btn btn--primary">Retour</a>
</div>
<div class="content-card">
    {% if error is defined and error %}
    <div class="alert alert--error">{{ error }}</div>
    {% endif %}
    <form method="post" class="auth-form">
        <div class="form-field">
            <label class="form-field__label" for="nom">Nom</label>
            <input class="form-field__input" type="text" id="nom" name="nom" placeholder="Nom" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="prenom">Prénom</label>
            <input class="form-field__input" type="text" id="prenom" name="prenom" placeholder="Prénom" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="email">Email</label>
            <input class="form-field__input" type="email" id="email" name="email" placeholder="email@exemple.fr" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="mot_de_passe">Mot de passe</label>
            <input class="form-field__input" type="password" id="mot_de_passe" name="mot_de_passe" required>
        </div>
        <button type="submit" class="btn btn--primary">Créer</button>
    </form>
</div>
{% endblock %}