{% extends 'base.html.twig' %}
{% block title %}Créer une offre{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Créer une offre</h1>
    <a href="/offers" class="btn btn--primary">Retour</a>
</div>
<div class="content-card">
    <form method="post" class="auth-form">
        <div class="form-field">
            <label class="form-field__label" for="titre">Titre</label>
            <input class="form-field__input" type="text" id="titre" name="titre" placeholder="Titre de l'offre" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="site_entreprise_id">Entreprise</label>
            <select class="form-field__input" name="site_entreprise_id" id="site_entreprise_id" required>
                {% for site in sites %}
                <option value="{{ site.id }}">{{ site.nom }} - {{ site.nom_site }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="date_debut">Date de début</label>
            <input class="form-field__input" type="date" id="date_debut" name="date_debut" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="duree_semaines">Durée (semaines)</label>
            <input class="form-field__input" type="number" min="1" max="52" id="duree_semaines" name="duree_semaines" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="gratification">Gratification (€/mois)</label>
            <input class="form-field__input" type="number" min="0" id="gratification" name="gratification" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="description">Description</label>
            <textarea class="form-field__input" id="description" name="description" placeholder="Vous devrez..." required></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Créer</button>
    </form>
</div>
{% endblock %}