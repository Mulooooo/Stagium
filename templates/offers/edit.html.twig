{% extends 'base.html.twig' %}
{% block title %}Modifier une offre{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Modifier {{ offer.titre }}</h1>
    <a href="/offers/show?id={{ offer.id }}" class="btn btn--primary">Retour</a>
</div>
<div class="content-card">
    <form method="post" class="auth-form">
        <div class="form-field">
            <label class="form-field__label" for="titre">Titre</label>
            <input class="form-field__input" type="text" id="titre" name="titre" value="{{ offer.titre }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="site_entreprise_id">Entreprise</label>
            <select class="form-field__input" name="site_entreprise_id" id="site_entreprise_id" required>
                {% for site in sites %}
                <option value="{{ site.id }}" {% if site.id == offer.site_entreprise_id %}selected{% endif %}>{{ site.nom }} - {{ site.nom_site }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="date_debut">Date de début</label>
            <input class="form-field__input" type="date" id="date_debut" name="date_debut" value="{{ offer.date_debut }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="duree_semaines">Durée (semaines)</label>
            <input class="form-field__input" type="number" min="1" max="52" id="duree_semaines" name="duree_semaines" value="{{ offer.duree_semaines }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="gratification">Gratification (€/mois)</label>
            <input class="form-field__input" type="number" min="0" id="gratification" name="gratification" value="{{ offer.gratification }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="description">Description</label>
            <textarea class="form-field__input" id="description" name="description" required>{{ offer.description }}</textarea>
        </div>
        <button type="submit" class="btn btn--primary">Modifier</button>
    </form>
</div>
{% endblock %}