{% extends 'base.html.twig' %}
{% block title %}Offres de stage{% endblock %}
{% block content %}
    <div class="page-header">
        <h1>Offres de stage</h1>
    </div>

    <div class="search-bar">
        <form method="get" action="/offers">
            <input class="search-bar__input" type="text" name="q" value="{{ filters.q }}" placeholder="Rechercher une offre...">
            <div class="filter-row">
                <input class="filter-select" type="text" name="location" value="{{ filters.location }}" placeholder="Ville...">
                <button class="btn btn--primary" type="submit">Rechercher</button>
            </div>
        </form>
    </div>
    
    <div class="offers-grid">
    {% for offer in offers %}
        {% include 'components/offer_card.html.twig' with { offer: offer } %}
    {% endfor %}
    </div>

    <div class="pagination">
        {% if current_page > 1 %}
            <a href="/offers?page={{ current_page - 1 }}" class="pagination__btn">Précédent</a>
        {% endif %}
        <span class="pagination__info">Page {{ current_page }} / {{ total_pages }}</span>
        {% if current_page < total_pages %}
            <a href="/offers?page={{ current_page + 1 }}" class="pagination__btn">Suivant</a>
        {% endif %}
    </div>
{% endblock %}