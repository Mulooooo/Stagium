{% extends 'base.html.twig' %}
{% block title %}
    Offres de stage
{% endblock %}
{% block content %}
    <div>
    {% for offer in offers %}
        <div>
        <a href="/offers/show?id={{ offer.id }}">{{ offer.titre }}</a>
        <p>{{ offer.nom }}</p>
        <p>{{ offer.ville }}</p>
        <p>{{ offer.date_debut }}</p>
        <p>{{ offer.duree_semaines }}</p>
        <p>{{ offer.gratification }}</p>
        </div>
    {% endfor %}
    </div>
    {% if total_pages > 1 %}
    {% if current_page > 1 %}
        <a href="/offers?page={{ current_page - 1 }}">Précédent</a>
    {% endif %}
    
    <span>Page {{ current_page }} / {{ total_pages }}</span>
    
    {% if current_page < total_pages %}
        <a href="/offers?page={{ current_page + 1 }}">Suivant</a>
    {% endif %}
{% endif %}
{% endblock %}