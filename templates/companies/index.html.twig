{% extends 'base.html.twig' %}
{% block title %}
    Entreprises
{% endblock %}
{% block content %}
    <div>
    {% for company in companies %}
        <div>
        <a href="/companies/show?id={{ company.id }}">{{ company.nom }}</a>
        </div>
    {% endfor %}
    </div>
    {% if total_pages > 1 %}
    {% if current_page > 1 %}
        <a href="/companies?page={{ current_page - 1 }}">Précédent</a>
    {% endif %}
    
    <span>Page {{ current_page }} / {{ total_pages }}</span>
    
    {% if current_page < total_pages %}
        <a href="/companies?page={{ current_page + 1 }}">Suivant</a>
    {% endif %}
    {% endif %}
{% endblock %}