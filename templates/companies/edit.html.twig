{% extends 'base.html.twig' %}
{% block title %}Modifier une entreprise{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Modifier {{ company.nom }}</h1>
    <a href="/companies/show?id={{ company.id }}" class="btn btn--primary">Retour</a>
</div>
{% if error is defined and error %}
    <div class="alert alert--error">{{ error }}</div>
{% endif %}

<div class="content-card">
    <form method="post" class="auth-form">
        <div class="form-field">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}"><div class="form-field">
        
            <label class="form-field__label" for="nom">Nom de l'entreprise</label>
            <input class="form-field__input" type="text" id="nom" name="nom" value="{{ company.nom }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="email">Email</label>
            <input class="form-field__input" type="email" id="email" name="email" value="{{ company.email }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="telephone">Téléphone</label>
            <input class="form-field__input" type="tel" pattern="\d{10}" id="telephone" name="telephone" value="{{ company.telephone }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="siren">SIREN</label>
            <input class="form-field__input" type="text" pattern="\d{9}" id="siren" name="siren" value="{{ company.siren }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="description">Description</label>
            <textarea class="form-field__input" id="description" name="description" required>{{ company.description }}</textarea>
        </div>
        <button type="submit" class="btn btn--primary">Modifier</button>
    </form>
</div>
{% endblock %}