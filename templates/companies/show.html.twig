{% extends 'base.html.twig' %}
{% block title %}{{ company.nom }}{% endblock %}
{% block content %}
<div class="page-header">
    <h1>{{ company.nom }}</h1>
    <a href="/companies" class="btn btn--primary">Retour</a>
</div>

<div class="offer-detail">
    <p class="offer-detail__company">{{ company.description }}</p>
    <p class="offer-detail__location">email : {{ company.email }}</p>
    <p class="offer-detail__date">telephone : {{ company.telephone }}</p>
    <p class="offer-detail__duration">SIREN : {{ company.siren }}</p>
    {% if user_role in ['pilote', 'administrateur'] %}
    <div class="offer-detail__actions">
        <a href="/companies/edit?id={{ company.id }}" class="btn btn--primary">Modifier</a>
        <form method="post" action="/companies/delete">
            <input type="hidden" name="id" value="{{ company.id }}">
            <button type="submit" class="btn btn--danger">Supprimer</button>
        </form>
    </div>
    {% endif %}
</div>

{% if user_role in ['pilote', 'administrateur'] %}
<div class="content-card">
    <h2 class="content-card__title">Évaluer cette entreprise</h2>
    <form method="post" action="/companies/evaluate" class="auth-form">
        <input type="hidden" name="entreprise_id" value="{{ company.id }}">
        <div class="form-field">
            <label class="form-field__label" for="note">Note (1 à 5)</label>
            <input class="form-field__input" type="number" id="note" name="note" min="1" max="5" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="commentaire">Commentaire</label>
            <textarea class="form-field__input" id="commentaire" name="commentaire"></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Envoyer</button>
    </form>
</div>
{% endif %}

<div class="content-card">
    <h2 class="content-card__title">Évaluations</h2>
    {% if evaluations %}
        {% for eval in evaluations %}
        <div class="content-card" style="margin-bottom: 0.75rem;">
            <p><strong>Note : {{ eval.note }}/5</strong></p>
            <p>{{ eval.commentaire }}</p>
            <p class="offer-detail__date">{{ eval.date_evaluation }}</p>
        </div>
        {% endfor %}
    {% else %}
        <p>Aucune évaluation pour cette entreprise.</p>
    {% endif %}
</div>

<div class="content-card">
    <h2 class="content-card__title">Sites</h2>
    {% if sites %}
        {% for site in sites %}
        <div class="company-card">
            <div class="company-card__body">
                <p class="company-card__name">{{ site.nom_site }}</p>
                <p class="company-card__desc">{{ site.rue }}, {{ site.code_postal }} {{ site.ville }}</p>
                <p class="company-card__desc">SIRET : {{ site.siret }}</p>
            </div>
        </div>
        {% endfor %}
    {% else %}
        <p>Aucun site pour cette entreprise.</p>
    {% endif %}
</div>

{% if user_role in ['pilote', 'administrateur'] %}
<div class="content-card">
    <h2 class="content-card__title">Ajouter un site</h2>
    <form method="post" action="/companies/sites/create" class="auth-form">
        <input type="hidden" name="entreprise_id" value="{{ company.id }}">
        <div class="form-field">
            <label class="form-field__label">Nom du site</label>
            <input class="form-field__input" type="text" name="nom_site" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">Numéro de rue</label>
            <input class="form-field__input" type="text" name="numero" maxlength="8" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">Rue</label>
            <input class="form-field__input" type="text" name="rue" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">Code postal</label>
            <input class="form-field__input" type="text" pattern="\d{5}" name="code_postal" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">Ville</label>
            <input class="form-field__input" type="text" name="ville" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">SIRET (14 chiffres)</label>
            <input class="form-field__input" type="text" pattern="\d{14}" name="siret" required>
        </div>
        <div class="form-field">
            <label class="form-field__label">Pays</label>
            <input class="form-field__input" type="text" name="pays" value="France">
        </div>
        <button type="submit" class="btn btn--primary">Ajouter</button>
    </form>
</div>
{% endif %}

<div class="content-card">
    <h2 class="content-card__title">Offres de stage</h2>
    {% if offers is defined and offers %}
        {% for offer in offers %}
            {% include 'components/offer_card.html.twig' with { offer: offer } %}
        {% endfor %}
    {% else %}
        <p>Aucune offre disponible pour cette entreprise.</p>
    {% endif %}
</div>
{% endblock %}