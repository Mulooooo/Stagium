{% extends 'base.html.twig' %}
{% block title %}{{ company.nom }}{% endblock %}
{% block content %}
<div class="page-header">
    <h1>{{ company.nom }}</h1>
    <a href="/companies" class="btn btn--primary">Retour</a>
</div>

<div class="offer-detail">
    <p class="offer-detail__company">{{ company.description }}</p>
    <p class="offer-detail__location">email : {{ company.email }}</p>
    <p class="offer-detail__date">telephone : {{ company.telephone }}</p>
    <p class="offer-detail__duration">SIREN : {{ company.siren }}</p>
    {% if user_role in ['pilote', 'administrateur'] %}
    <div class="offer-detail__actions">
        <a href="/companies/edit?id={{ company.id }}" class="btn btn--primary">Modifier</a>
        <form method="post" action="/companies/delete">
            <input type="hidden" name="id" value="{{ company.id }}">
            <button type="submit" class="btn btn--danger">Supprimer</button>
        </form>
    </div>
    {% endif %}
</div>

{% if user_role in ['pilote', 'administrateur'] %}
<div class="content-card">
    <h2 class="content-card__title">Évaluer cette entreprise</h2>
    <form method="post" action="/companies/evaluate" class="auth-form">
        <input type="hidden" name="entreprise_id" value="{{ company.id }}">
        <div class="form-field">
            <label class="form-field__label" for="note">Note (1 à 5)</label>
            <input class="form-field__input" type="number" id="note" name="note" min="1" max="5" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="commentaire">Commentaire</label>
            <textarea class="form-field__input" id="commentaire" name="commentaire"></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Envoyer</button>
    </form>
</div>
{% endif %}

<div class="content-card">
    <h2 class="content-card__title">Évaluations</h2>
    {% if evaluations %}
        {% for eval in evaluations %}
        <div class="content-card" style="margin-bottom: 0.75rem;">
            <p><strong>Note : {{ eval.note }}/5</strong></p>
            <p>{{ eval.commentaire }}</p>
            <p class="offer-detail__date">{{ eval.date_evaluation }}</p>
        </div>
        {% endfor %}
    {% else %}
        <p>Aucune évaluation pour cette entreprise.</p>
    {% endif %}
</div>

<div class="content-card">
    <h2 class="content-card__title">Offres de stage</h2>
    {% if offers is defined and offers %}
        {% for offer in offers %}
            {% include 'components/offer_card.html.twig' with { offer: offer } %}
        {% endfor %}
    {% else %}
        <p>Aucune offre disponible pour cette entreprise.</p>
    {% endif %}
</div>
{% endblock %}