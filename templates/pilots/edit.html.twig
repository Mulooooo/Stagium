{% extends 'base.html.twig' %}
{% block title %}Modifier {{ pilot.prenom }} {{ pilot.nom }}{% endblock %}
{% block content %}
<div class="page-header">
    <h1>Modifier {{ pilot.prenom }} {{ pilot.nom }}</h1>
    <a href="/pilots/show?id={{ pilot.id }}" class="btn btn--primary">Retour</a>
</div>
<div class="content-card">
    <form method="post" class="auth-form">
        <div class="form-field">
            <label class="form-field__label" for="nom">Nom</label>
            <input class="form-field__input" type="text" id="nom" name="nom" value="{{ pilot.nom }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="prenom">Prénom</label>
            <input class="form-field__input" type="text" id="prenom" name="prenom" value="{{ pilot.prenom }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="email">Email</label>
            <input class="form-field__input" type="email" id="email" name="email" value="{{ pilot.email }}" required>
        </div>
        <div class="form-field">
            <label class="form-field__label" for="mot_de_passe">Mot de passe</label>
            <input class="form-field__input" type="password" id="mot_de_passe" name="mot_de_passe" placeholder="Laisser vide pour ne pas modifier">
        </div>
        <button type="submit" class="btn btn--primary">Modifier</button>
    </form>
</div>
{% endblock %}