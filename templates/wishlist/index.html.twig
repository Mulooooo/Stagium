{% extends 'base.html.twig' %}
{% block title %}
    Wishlist
{% endblock %}
{% block content %}
    <div>
    {% for offer in offers %}
        <div>
        <a href="/offers/show?id={{ offer.id }}">{{ offer.titre }}</a>
        <p>{{ offer.nom }}</p>
        <p>{{ offer.ville }}</p>
        <p>{{ offer.date_debut }}</p>
        <p>{{ offer.duree_semaines }}</p>
        <p>{{ offer.gratification }}</p>
        </div>
    {% endfor %}
    </div>
{% endblock %}